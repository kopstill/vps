{
  "routing": {
    "domainStrategy": "AsIs",
    "rules": [
      {
        "type": "field",
        "ruleTag": "block-bittorrent",
        "protocol": ["bittorrent"],
        "outboundTag": "block"
      },
      {
        "type": "field",
        "ruleTag": "block-ads",
        "domain": ["geosite:category-ads-all"],
        "outboundTag": "block"
      },
      {
        "type": "field",
        "ruleTag": "block-private-ip",
        "ip": ["geoip:private"],
        "outboundTag": "block"
      },
      {
        "type": "field",
        "ruleTag": "direct-catch-all",
        "network": "tcp,udp",
        "outboundTag": "direct"
      }
    ]
  }
}
