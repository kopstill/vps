{
  "dns": {
    "hosts": {
      "geosite:category-ads-all": "127.0.0.1"
    },
    "servers": [
      {
        "address": "https://1.1.1.1/dns-query",
        "domains": [
          "geosite:gfw",
          "geosite:category-anticensorship",
          "geosite:telegram"
        ],
        "expectedIPs": [
          "geoip:!cn"
        ]
      },
      {
        "address": "https://1.0.0.1/dns-query",
        "domains": [
          "geosite:gfw",
          "geosite:category-anticensorship",
          "geosite:telegram"
        ],
        "expectedIPs": [
          "geoip:!cn"
        ]
      },
      {
        "address": "223.5.5.5",
        "domains": [
          "geosite:cn"
        ],
        "expectedIPs": [
          "geoip:cn"
        ],
        "skipFallback": true
      }
    ]
  },
  "routing": {
    "domainStrategy": "IPIfNonMatch",
    "rules": [
      {
        "type": "field",
        "ruleTag": "block-ads",
        "domain": [
          "geosite:category-ads-all"
        ],
        "outboundTag": "block"
      },
      {
        "type": "field",
        "ruleTag": "block-bittorrent",
        "protocol": [
          "bittorrent"
        ],
        "outboundTag": "block"
      },
      {
        "type": "field",
        "ruleTag": "direct-private-domains",
        "domain": [
          "geosite:private",
          "geosite:cn"
        ],
        "outboundTag": "direct"
      },
      {
        "type": "field",
        "ruleTag": "proxy-gfw-domains",
        "domain": [
          "geosite:gfw",
          "geosite:category-anticensorship",
          "geosite:telegram"
        ],
        "outboundTag": "proxy"
      },
      {
        "type": "field",
        "ruleTag": "direct-private-ip",
        "ip": [
          "geoip:private"
        ],
        "outboundTag": "direct"
      },
      {
        "type": "field",
        "ruleTag": "direct-cn-hk-mo-ip",
        "ip": [
          "geoip:cn",
          "geoip:hk",
          "geoip:mo"
        ],
        "outboundTag": "direct"
      },
      {
        "type": "field",
        "ruleTag": "proxy-telegram-ip",
        "ip": [
          "geoip:telegram"
        ],
        "outboundTag": "proxy"
      },
      {
        "type": "field",
        "ruleTag": "direct-catch-all",
        "network": "tcp,udp",
        "outboundTag": "direct"
      }
    ]
  }
}
